# Host IP or domain that BOTH the browser and the WOPI containers (Collabora /
# OnlyOffice) use to reach Cloudreve. It must equal Cloudreve's Site URL host.
#
# Setup:  cp .env.example .env   then edit HOST_IP to this machine's address.
# After changing it:  docker compose up -d   (recreates the affected containers)
# Remember to also set Cloudreve Site URL = http://<HOST_IP>:5212 (admin or DB).
HOST_IP=192.168.233.69
