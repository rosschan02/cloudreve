# ---- Deployment host ----
# IP or domain that BOTH the browser and the WOPI containers (Collabora / OnlyOffice)
# use to reach Cloudreve. Must equal Cloudreve's Site URL host.
HOST_IP=192.168.233.69

# ---- Database (PostgreSQL) ----
# On a FRESH deployment (empty db volume) these initialise the database.
# For an EXISTING trust-auth volume, changing DB_PASSWORD does NOT take effect
# automatically — run:  ALTER USER <DB_USER> PASSWORD '<DB_PASSWORD>';  in psql.
DB_USER=cloudreve
DB_NAME=cloudreve
DB_PASSWORD=change-me-to-a-strong-db-password

# ---- Collabora admin console (http://<HOST_IP>:9980/browser/dist/admin/admin.html) ----
COLLABORA_PASSWORD=change-me-collabora-admin

# Setup:  cp .env.example .env   then edit the values.
# After changing:  docker compose up -d
# Also set Cloudreve Site URL = http://<HOST_IP>:5212 (admin or DB).
